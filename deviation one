class TerminalEdition:
    """Terminal interface for EGGLE Chill"""
    
    def __init__(self):
        self.history = []
        self.chill_mode = True
        self.prompt = "EGGLE::CHILL> "
    
    def display_mandala(self, style: str = "default"):
        print(render_mandala(style))
    
    def display_kitten(self, mood: str = "chill"):
        print(get_kitten(mood))
    
    def process_input(self, command: str) -> str:
        self.history.append(command)
        
        if command.lower() == "chill":
            return "😎 Everything is chill..."
        elif command.lower() == "mandala":
            return render_mandala()
        elif command.lower() == "kitten":
            return get_kitten()
        else:
            return f"EGGLE echoes: {command}"
    
    def get_status(self) -> Dict:
        return {
            "mode": "chill" if self.chill_mode else "active",
            "history_length": len(self.history),
            "prompt": self.prompt
        }

