class Triggers:
    """Event triggers for EGGLE Chill actions"""
    
    def __init__(self):
        self.triggers = {}
        self.trigger_history = []
    
    def register(self, event_name: str, action: callable):
        self.triggers[event_name] = action
    
    def fire(self, event_name: str, *args, **kwargs) -> Any:
        if event_name in self.triggers:
            result = self.triggers[event_name](*args, **kwargs)
            self.trigger_history.append({"event": event_name, "result": result})
            return result
        return None
    
    def list_triggers(self) -> List[str]:
        return list(self.triggers.keys())

