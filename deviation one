class BroadcastSignal:
    """Signal broadcasting for EGGLE Chill network"""
    
    def __init__(self):
        self.signals = []
        self.listeners = []
    
    def create_signal(self, signal_type: str, payload: Any) -> Dict:
        signal = {
            "type": signal_type,
            "payload": payload,
            "origin": "EGGLE_CHILL",
            "chill_factor": random.randint(1, 10)
        }
        self.signals.append(signal)
        return signal
    
    def broadcast(self, signal: Dict) -> List[Any]:
        """Broadcast to all listeners"""
        responses = []
        for listener in self.listeners:
            try:
                response = listener(signal)
                responses.append(response)
            except Exception as e:
                responses.append({"error": str(e)})
        return responses
    
    def subscribe(self, listener: callable):
        self.listeners.append(listener)
    
    def get_signal_history(self) -> List[Dict]:
        return self.signals

