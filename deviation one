class NodeEdition:
    """Network node for EGGLE Chill distribution"""
    
    def __init__(self, node_id: str = "EGGLE_NODE_001"):
        self.node_id = node_id
        self.connections = []
        self.chill_signals = []
        self.is_active = True
    
    def connect(self, peer_address: str) -> bool:
        self.connections.append(peer_address)
        return True
    
    def broadcast(self, message: str) -> List[str]:
        """Broadcast to all connected peers"""
        responses = []
        for peer in self.connections:
            responses.append(f"Sent to {peer}: {message}")
        return responses
    
    def receive_chill(self, signal: Dict) -> None:
        self.chill_signals.append(signal)
    
    def node_info(self) -> Dict:
        return {
            "node_id": self.node_id,
            "connections": len(self.connections),
            "signals_received": len(self.chill_signals),
            "active": self.is_active
        }

