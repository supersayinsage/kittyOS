class ObserverLogic:
    """Observer pattern for EGGLE Chill monitoring"""
    
    def __init__(self):
        self.observers = {}
        self.state = {}
    
    def attach(self, event: str, observer: callable):
        if event not in self.observers:
            self.observers[event] = []
        self.observers[event].append(observer)
    
    def notify(self, event: str, data: Any = None):
        if event in self.observers:
            for observer in self.observers[event]:
                observer(data)
    
    def watch(self, key: str, value: Any):
        """Update state and notify watchers"""
        old_value = self.state.get(key)
        self.state[key] = value
        self.notify(f"change:{key}", {"old": old_value, "new": value})
    
    def get_state(self, key: str = None) -> Any:
        if key:
            return self.state.get(key)
        return self.state

