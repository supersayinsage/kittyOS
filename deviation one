@dataclass
class Slot:
    name: str
    content: Any
    is_active: bool = True
    priority: int = 0

class Slots:
    """Slot management system for EGGLE Chill"""
    
    def __init__(self, max_slots: int = 10):
        self.slots: Dict[str, Slot] = {}
        self.max_slots = max_slots
    
    def add_slot(self, name: str, content: Any, priority: int = 0) -> bool:
        if len(self.slots) >= self.max_slots:
            return False
        self.slots[name] = Slot(name=name, content=content, priority=priority)
        return True
    
    def get_slot(self, name: str) -> Optional[Any]:
        if name in self.slots and self.slots[name].is_active:
            return self.slots[name].content
        return None
    
    def remove_slot(self, name: str) -> bool:
        if name in self.slots:
            del self.slots[name]
            return True
        return False
    
    def list_slots(self) -> List[str]:
        return list(self.slots.keys())

