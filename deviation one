class EGGLEChillJSON:
    """JSON handler for EGGLE Chill data structures"""
    
    @staticmethod
    def encode(data: Any) -> str:
        """Encode EGGLE data to JSON with chill formatting"""
        return json.dumps(data, indent=2, ensure_ascii=False)
    
    @staticmethod
    def decode(json_str: str) -> Any:
        """Decode JSON back to EGGLE objects"""
        return json.loads(json_str)
    
    @staticmethod
    def create_chill_packet(content: Any, sender: str = "EGGLE") -> Dict:
        """Create a standardized chill packet"""
        return {
            "protocol": "EGGLE_CHILL",
            "version": "1.0.0",
            "sender": sender,
            "content": content,
            "timestamp": "NOW"  # Would use datetime in production
        }

