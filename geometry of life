@dataclass
class NodeMutation:
    name: str
    public_domain: str
    taoism: str
    shinto: str
    objects_of_power: List[str]
    words_of_power: List[str]
    contexts: Dict[str, str]

# =========================
# Hella Engine
# =========================

class HellaEngine:
    def __init__(self, config: Dict):
        self.pd_seal = config.get("seal", "☯ PD")
        self.nodes = self._load_nodes(config.get("nodes", []))
        self.phases = config.get("phases", PHASES)
        self.cycles = config.get("cycles", CYCLES)
        self.mode = config.get("mode", "festival")

    def _load_nodes(self, node_cfgs: List[Dict]) -> List[NodeMutation]:
        nodes = []
        for n in node_cfgs:
            nodes.append(
                NodeMutation(
                    name=n["name"],
                    public_domain=n["public_domain"],
                    taoism=n["taoism"],
                    shinto=n["shinto"],
                    objects_of_power=n.get("objects_of_power", []),
                    words_of_power=n.get("words_of_power", []),
                    contexts=n.get("contexts", {}),
                )
            )
        return nodes

    def render_node(self, node: NodeMutation, cycle: str, phase: str) -> str:
        parts = [
            f"[{cycle}:{phase}] {node.name}",
            f"PD={node.public_domain}",
            f"Tao={node.taoism}",
            f"Shinto={node.shinto}",
        ]
        if self.mode == "festival":
            if node.objects_of_power:
                parts.append(f"Objects={', '.join(node.objects_of_power)}")
            if node.words_of_power:
                parts.append(f"Words={', '.join(node.words_of_power)}")
            # Context overlays
            surf = node.contexts.get("surfing")
            sand = node.contexts.get("sandcastle")
            if surf:
                parts.append(f"Surfing={surf}")
            if sand:
                parts.append(f"Sandcastle={sand}")
        return " | ".join(parts)

    def run(self, loops: int = 1) -> None:
        banner = f"=== {self.pd_seal} Hella Validator (mode={self.mode}) ==="
        print(banner)
        for L in range(loops):
            print(f"--- Loop {L+1}/{loops} ---")
            for cycle in self.cycles:
                for phase in self.phases.get(cycle, ["Neutral"]):
                    for node in self.nodes:
                        print(self.render_node(node, cycle, phase))
            print(f"--- Completion: Tide wash & ritual closure ({self.pd_seal}) ---")

